{
  "name": "lark-acp-bridge",
  "version": "0.1.4",
  "description": "Bridge Feishu/Lark to any ACP-compatible AI agent (Claude Code, Kiro, Gemini, Amazon Q, ...)",
  "type": "module",
  "files": [
    "dist/",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "lark-acp": "dist/bin/lark-acp.js",
    "lark-acp-mock": "dist/bin/mock-agent.js",
    "lark-acp-q": "dist/bin/q-acp.js",
    "lark-acp-copilot-studio": "dist/bin/copilot-studio-acp.js",
    "lark-acp-m365": "dist/bin/m365-copilot-acp.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"for (const f of ['dist/bin/lark-acp.js','dist/bin/mock-agent.js','dist/bin/q-acp.js','dist/bin/copilot-studio-acp.js','dist/bin/m365-copilot-acp.js']) require('fs').chmodSync(f, 0o755)\"",
    "prepare": "npm run build",
    "start": "node dist/bin/lark-acp.js",
    "dev": "tsc -p tsconfig.build.json --watch",
    "pretest": "npm run build",
    "test": "vitest run",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.21.1",
    "@azure/msal-node": "^5.4.0",
    "@larksuiteoapi/node-sdk": "^1.65.0",
    "@microsoft/agents-activity": "^1.6.1",
    "@microsoft/agents-copilotstudio-client": "^1.6.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "marked": "^18.0.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "eslint": "^10.7.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wthislifehuh/lark-acp-bridge.git"
  },
  "homepage": "https://github.com/wthislifehuh/lark-acp-bridge#readme",
  "bugs": {
    "url": "https://github.com/wthislifehuh/lark-acp-bridge/issues"
  },
  "author": "JOEEE",
  "license": "MIT",
  "keywords": [
    "feishu",
    "lark",
    "acp",
    "agent-client-protocol",
    "ai-agent",
    "bridge",
    "feishu-bot",
    "lark-bot",
    "chatbot",
    "claude-code",
    "claude",
    "kiro",
    "codex",
    "gemini-cli",
    "github-copilot",
    "amazon-q",
    "copilot-studio",
    "microsoft-copilot",
    "m365-copilot",
    "opencode",
    "llm"
  ]
}
