{
  "name": "@4t145/lark-acp",
  "version": "0.1.0",
  "description": "Bridge Feishu/Lark to any ACP-compatible AI agent",
  "type": "module",
  "files": [
    "dist/",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "lark-acp": "./dist/bin/lark-acp.js",
    "lark-acp-mock": "./dist/bin/mock-agent.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/bin/lark-acp.js",
    "dev": "tsc --watch",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check ."
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@larksuiteoapi/node-sdk": "^1.65.0",
    "marked": "^18.0.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/4t145/lark-acp.git"
  },
  "license": "MIT",
  "keywords": [
    "feishu",
    "lark",
    "acp",
    "agent-client-protocol",
    "ai-agent",
    "bridge"
  ]
}
